# ─────────────────────────────────────────────────────────
#  Copia este archivo como  .env  y rellena los valores
#  NUNCA subas .env a GitHub (ya está en .gitignore)
# ─────────────────────────────────────────────────────────

# Base de datos
DB_URL=jdbc:postgresql://localhost:5432/distribuidora_huevos
DB_USERNAME=distribuidora
DB_PASSWORD=cambia_esta_contrasena_segura

# Puerto del servidor (opcional, default 8080)
PORT=8080

# ── Credenciales de la aplicación ─────────────────────────
# En producción (Railway): configurar como variables de entorno del servicio.
# ⚠️  Sin estas variables el servidor NO arranca en perfil prod.
APP_USERNAME=admin
APP_PASSWORD=cambia_esta_contrasena_segura

# ── JWT ───────────────────────────────────────────────────
# Mínimo 64 caracteres aleatorios. Generar con:
#   openssl rand -hex 64
JWT_SECRET=genera_un_secreto_de_minimo_64_caracteres_aleatorios_aqui_00000000

# ── CORS ──────────────────────────────────────────────────
# En producción: URL exacta de tu app en Railway (sin barra final).
# En local: http://localhost:5173
APP_ALLOWED_ORIGIN=https://TU-APP.up.railway.app
